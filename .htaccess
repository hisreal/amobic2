<IfModule mod_rewrite.c>
  RewriteEngine On

  # Keep local XAMPP usable, but force HTTPS for normal page visits in production.
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
  RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # AJAX/API endpoints must not be redirected away from POST requests.
  RewriteRule ^config/(send-code|update-code|property-draft|property-draft-get|property-draft-save|property-draft-update|property-images|property-submit)/?$ config/$1.php [L,QSA]

  # Redirect old page.php URLs to clean URLs for normal browser navigation only.
  RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
  RewriteCond %{REQUEST_URI} !/config/ [NC]
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
  RewriteRule ^(.+)\.php$ $1 [R=301,L,NE]

  # Remove trailing slash from non-directory URLs without breaking subfolder installs.
  RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ $1 [R=301,L]

  # Serve clean URLs like /signup from signup.php.
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^(.+?)/?$ $1.php [L,QSA]
</IfModule>
